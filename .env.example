# Vipps Checkout API Credentials
# Get these from portal.vipps.no (Developer Portal)
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=

# Vipps Webhook Callback Token (Generate a random string for this)
VIPPS_CALLBACK_TOKEN=

# Set to 'production' for live environment, 'test' for test environment
VIPPS_ENV=test

# Your app's base URL (e.g., http://localhost:3000 or your production domain)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend API Key (for emails later)
RESEND_API_KEY=